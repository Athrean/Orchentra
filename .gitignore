# not tracked (see .orchentra/), so this file names no paths.

# Turbo cache
.turbo/

# TS incremental build artifacts
*.tsbuildinfo

# IDE
.vscode/
.idea/

# Canonical product docs are tracked. The four pivot audits are immutable,
# local source material and remain outside product history.
docs/discovery/
# Tracked product docs that live alongside the app they document
!apps/*/docs/
UBIQUITOUS_LANGUAGE.md

# Local agent/IDE plugin folders (not part of the product repo)
.claude-plugins/
.claude/plugins/

