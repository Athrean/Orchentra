# Orchentra environment template — copy to .env.dev (gitignored) and fill values.
# Never commit real values. .env.example is the only env file tracked in git.
# The product is CLI-only and zero-DB; per-user credentials via /login are the
# preferred path. These are dev-loop fallbacks.

# ---- LLM providers ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- GitHub PAT (dev-loop only; /login github is the preferred path) ----
GITHUB_TOKEN=
