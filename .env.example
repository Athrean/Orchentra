# Orchentra environment template — copy to .env.dev (gitignored) and fill values.
# Never commit real values. .env.example is the only env file tracked in git.

# ---- Database (local Postgres or Supabase Cloud) ----
DATABASE_URL=

# ---- App ----
# Public base URL. Used for OAuth redirects + email links.
# Dev: http://localhost:3000   Prod: https://orchentra.<your-domain>
NEXT_PUBLIC_APP_URL=

# ---- Supabase ----
# Project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SERVER ONLY. Bypasses RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Secrets ----
# Generate each with: openssl rand -hex 32
CLI_TOKEN_SECRET=
LLM_KEY_ENCRYPTION_KEY=

# ---- LLM providers (per-user key preferred; these are dev-loop fallbacks) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- GitHub App (preferred auth path) ----
# Register at https://github.com/settings/apps. Capture all values immediately —
# client secret + private key are shown once. See docs/operations-backlog.md
# and ORCHENTRA_PLAN.md §3.3.5 for the wider credential model.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/orchentra-app.pem
# Default install for the local dev loop. Optional — fetch via JWT on first run.
GITHUB_APP_INSTALLATION_ID=

# ---- GitHub PAT fallback (used when GITHUB_APP_* is unset) ----
# Classic PAT or fine-grained PAT. Dev-loop only; do not use in prod.
GITHUB_TOKEN=

# ---- Webhook dev forwarder (smee.io) ----
# Create a channel at https://smee.io and forward to the local server:
#   smee -u $SMEE_WEBHOOK_URL -t http://localhost:3000/webhooks/github
SMEE_WEBHOOK_URL=
