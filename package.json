{
  "name": "orchentra",
  "packageManager": "bun@1.3.9",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "test": "bun run test:precommit",
    "test:precommit": "bun test packages/cli-core/tests packages/cli-api/tests packages/cli-tools/tests packages/brain/tests apps/cli/tests apps/web/tests",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint-config-next": "^16.1.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.8.17",
    "eslint-plugin-turbo": "^2.8.17",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.0",
    "turbo": "^2.1.0",
    "typescript": "^5.9.3"
  }
}
