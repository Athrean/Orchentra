{
  "name": "@orchentra/cli",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "orchentra": "./src/main.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun --external react-devtools-core",
    "build:binaries": "./scripts/build-binaries.sh",
    "build:binaries:host": "./scripts/build-binaries.sh host",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orchentra/cli-api": "workspace:*",
    "@orchentra/cli-core": "workspace:*",
    "@orchentra/cli-tools": "workspace:*",
    "@orchentra/mcp-server": "workspace:*",
    "@orchentra/operations": "workspace:*",
    "ink": "^7",
    "react": "^19",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@orchentra/eslint-config": "workspace:*",
    "@orchentra/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/react": "^19",
    "eslint": "^8.57.0",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.9.3"
  }
}
