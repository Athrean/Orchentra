{
  "name": "@athreanlab/orchentra",
  "version": "0.9.0",
  "description": "The local-first coding harness from Athrean Lab.",
  "author": "Athrean Lab",
  "homepage": "https://github.com/Athrean/Orchentra#readme",
  "bugs": {
    "url": "https://github.com/Athrean/Orchentra/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Athrean/Orchentra.git",
    "directory": "apps/cli"
  },
  "license": "Apache-2.0",
  "bin": {
    "orchentra": "dist/main.js",
    "otr": "dist/main.js"
  },
  "files": [
    "dist/main.js",
    "dist/keytar-*.node",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "build:binaries": "./scripts/build-binaries.sh",
    "build:binaries:host": "./scripts/build-binaries.sh host",
    "package:verify": "bun run scripts/verify-npm-package.ts",
    "package:dry-run": "npm pack --dry-run",
    "test:smoke": "./scripts/pack-smoke.sh",
    "prepack": "bun run build && bun run package:verify",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@orchentra/cli-api": "workspace:*",
    "@orchentra/cli-browser": "workspace:*",
    "@orchentra/cli-core": "workspace:*",
    "@orchentra/cli-tools": "workspace:*",
    "@orchentra/eslint-config": "workspace:*",
    "@orchentra/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/react": "^19",
    "eslint": "^8.57.0",
    "ink": "^7",
    "ink-testing-library": "^4.0.0",
    "react": "^19",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.9.3",
    "zod": "^3.23.8"
  }
}
