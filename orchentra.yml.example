github:
  webhook_secret: "your-webhook-secret"
  token: "ghp_xxx"
  oauth:
    client_id: "your-github-client-id"
    client_secret: "your-github-client-secret"
    redirect_uri: "http://localhost:3001/auth/github/callback"
  repos:
    - "my-org/api"
    - "my-org/frontend"

# Uses OpenRouter by default — access every frontier model with one key.
# Get your key at https://openrouter.ai/settings/keys
llm:
  api_key: "sk-or-xxx"
  model: "anthropic/claude-sonnet-4-5"
  # Optional: point to any OpenAI-compatible endpoint instead (zai, Ollama, etc.)
  # base_url: "https://api.z.ai/api/paas/v4"

integrations:
  sentry:
    auth_token: "sntryu_xxx"
    org: "my-org"
  # datadog:
  #   api_key: "xxx"
  #   app_key: "xxx"
