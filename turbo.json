{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_AUTH_TOKEN",
    "DATABASE_URL",
    "FRONTEND_URL",
    "GH_TOKEN",
    "GITHUB_TOKEN",
    "HOME",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL",
    "NODE_ENV",
    "NO_COLOR",
    "FORCE_COLOR",
    "COLORTERM",
    "TERM",
    "OPENAI_API_KEY",
    "ORCHENTRA_API_KEY",
    "ORCHENTRA_ALLOWED_ORGS",
    "ORCHENTRA_ORG_ID",
    "ORCHENTRA_SERVER_URL",
    "GEMINI_API_KEY",
    "GOOGLE_API_KEY",
    "XAI_API_KEY",
    "ORCHENTRA_GITHUB_CLIENT_ID",
    "ORCHENTRA_GITHUB_TOKEN",
    "ORCHENTRA_DEBUG",
    "ORCHENTRA_GITHUB_OAUTH_CLIENT_ID",
    "ORCHENTRA_NO_CLIPBOARD",
    "ANTHROPIC_OAUTH_CLIENT_ID",
    "ORCHENTRA_MEMORY_API_KEY",
    "ORCHESTRA_CONFIG_HOME",
    "ORCHENTRA_CONFIG_HOME",
    "ORCHESTRA_MODEL",
    "ORCHENTRA_SEARCH_URL",
    "ORCHENTRA_SEARCH_API_KEY",
    "LLM_CONFIG_SECRET",
    "PORT",
    "USER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "format": {
      "cache": false
    }
  }
}
