{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_AUTH_TOKEN",
    "GH_TOKEN",
    "GITHUB_TOKEN",
    "HOME",
    "NODE_ENV",
    "NO_COLOR",
    "FORCE_COLOR",
    "COLORTERM",
    "TERM",
    "TERM_PROGRAM",
    "PATH",
    "OPENAI_API_KEY",
    "ORCHENTRA_API_KEY",
    "ORCHENTRA_ORG_ID",
    "ORCHENTRA_SERVER_URL",
    "GEMINI_API_KEY",
    "GEMINI_BASE_URL",
    "GEMINI_OAUTH_CLIENT_ID",
    "GEMINI_OAUTH_CLIENT_SECRET",
    "GEMINI_OAUTH_TOKEN",
    "GOOGLE_API_KEY",
    "XAI_API_KEY",
    "ORCHENTRA_GITHUB_TOKEN",
    "ORCHENTRA_DEBUG",
    "ORCHENTRA_GITHUB_OAUTH_CLIENT_ID",
    "ORCHENTRA_NO_CLIPBOARD",
    "ORCHENTRA_SANDBOX_DISABLED",
    "CLAUDE_CODE_OAUTH_TOKEN",
    "ORCHENTRA_MEMORY_API_KEY",
    "ORCHESTRA_CONFIG_HOME",
    "ORCHENTRA_CONFIG_HOME",
    "ORCHENTRA_HOME",
    "ORCHESTRA_MODEL",
    "ORCHENTRA_MODEL",
    "ORCHENTRA_SEARCH_URL",
    "ORCHENTRA_SEARCH_API_KEY",
    "USER",
    "EDITOR",
    "VISUAL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "format": {
      "cache": false
    }
  }
}
