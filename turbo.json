{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_AUTH_TOKEN",
    "DATABASE_URL",
    "FRONTEND_URL",
    "GH_TOKEN",
    "GITHUB_TOKEN",
    "HOME",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL",
    "NODE_ENV",
    "ORCHENTRA_ALLOWED_ORGS",
    "ORCHENTRA_GITHUB_CLIENT_ID",
    "ORCHENTRA_GITHUB_TOKEN",
    "ORCHESTRA_CONFIG_HOME",
    "ORCHESTRA_MODEL",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "format": {
      "cache": false
    }
  }
}
